@{
    ViewData["Title"] = "404 - Page Not Found";
    Layout = "_CustomerLayout";
}

<div class="container py-5 my-5">
    <div class="row justify-content-center text-center">
        <div class="col-lg-7">
            <div class="position-relative mb-5">
                <div class="display-1 fw-bold text-coffee opacity-10" style="font-size: 10rem;">404</div>
                <div class="position-absolute top-50 start-50 translate-middle w-100">
                    <i class="fas fa-mug-hot fa-6x text-coffee mb-3"></i>
                    <h1 class="display-5 fw-bold text-dark">Oops! Spill on Aisle 404</h1>
                </div>
            </div>
            
            <h3 class="fw-bold mb-4">The page you're looking for has evaporated.</h3>
            <p class="text-muted fs-5 mb-5 px-lg-5">
                Don't let a missing page ruin your coffee break. Let's get you back to something delicious.
            </p>
            
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-coffee btn-lg rounded-pill px-5 py-3 shadow">
                    <i class="fas fa-home me-2"></i> Go Home
                </a>
                <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-dark btn-lg rounded-pill px-5 py-3">
                    <i class="fas fa-utensils me-2"></i> View Menu
                </a>
            </div>
            
            <div class="mt-5 pt-5 border-top opacity-50">
                <p class="small text-muted mb-0">Error Reference: HTTP_404_NOT_FOUND</p>
            </div>
        </div>
    </div>
</div>
