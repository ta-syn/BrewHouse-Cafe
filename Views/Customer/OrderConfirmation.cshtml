@model CafeManagement.Models.Order
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Order Confirmed";
    bool isPaid = Model.PaymentStatus == "Paid";
    bool isPartial = Model.PaymentStatus == "Partially Paid";
}

<div class="container mt-5 py-5">
    <div class="row justify-content-center">
        <div class="col-xl-7 col-lg-9">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
                <div class="card-header @(isPaid ? "bg-success" : "bg-coffee") text-white py-5 position-relative overflow-hidden">
                    <div class="celebration-background"></div>
                    <div class="position-relative z-1">
                        <div class="mb-4">
                            <i class="fas @(isPaid ? "fa-check-circle" : "fa-clock") fa-5x shadow-sm rounded-circle bg-white @(isPaid ? "text-success" : "text-coffee") p-2"></i>
                        </div>
                        <h1 class="display-5 fw-bold mb-0">@(isPaid ? "Payment Successful!" : "Order Confirmed!")</h1>
                        <p class="opacity-75 mb-0">Order #@Model.Id • @(isPaid ? "Thank you for your payment." : "Please proceed to pay or pay at counter.")</p>
                    </div>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="mb-4">
                        <h5 class="text-muted small text-uppercase fw-bold mb-3">Order Items</h5>
                        <div class="bg-light rounded-4 p-3 text-start">
                            @foreach (var item in Model.OrderItems)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <span class="fw-bold">@item.Quantity × @item.ItemName</span>
                                        @if (item.IsPaid) {
                                            <span class="badge bg-success-subtle text-success border border-success border-opacity-25 rounded-pill ms-2 small">Paid</span>
                                        }
                                    </div>
                                    <span class="text-muted">৳@item.Subtotal</span>
                                </div>
                            }
                            <hr class="my-2 border-secondary border-opacity-25">
                            <div class="d-flex justify-content-between fw-bold text-coffee fs-5">
                                <span>Total Amount</span>
                                <span>৳@Model.TotalAmount</span>
                            </div>
                        </div>
                    </div>

                    @if (!isPaid)
                    {
                        <div class="mb-5">
                            <h5 class="text-dark fw-bold mb-3"><i class="fas fa-credit-card me-2"></i> Choose Payment Method</h5>
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <a asp-controller="Payment" asp-action="Gateway" asp-route-orderId="@Model.Id" asp-route-method="bKash" class="payment-method-card bKash text-decoration-none">
                                        <img src="https://www.logo.wine/a/logo/BKash/BKash-Logo.wine.svg" height="40">
                                        <span class="d-block mt-2 small fw-bold">bKash</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <a asp-controller="Payment" asp-action="Gateway" asp-route-orderId="@Model.Id" asp-route-method="Nagad" class="payment-method-card Nagad text-decoration-none">
                                        <img src="https://download.logo.wine/logo/Nagad/Nagad-Logo.wine.png" height="40">
                                        <span class="d-block mt-2 small fw-bold">Nagad</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <a asp-controller="Payment" asp-action="Gateway" asp-route-orderId="@Model.Id" asp-route-method="SSLCommerz" class="payment-method-card text-decoration-none" style="border-color: #00457C;">
                                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" height="40">
                                        <span class="d-block mt-2 small fw-bold" style="color: #00457C;">SSLCommerz</span>
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <button class="payment-method-card bg-secondary bg-opacity-10 text-dark border-0 w-100" onclick="showSplitBillModal()">
                                        <i class="fas fa-columns fa-2x mb-2 text-primary"></i>
                                        <span class="d-block small fw-bold">Split Bill</span>
                                    </button>
                                </div>

                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success border-0 rounded-4 py-3 mb-5">
                            <i class="fas fa-receipt me-2"></i> <b>Transaction ID:</b> @Model.TransactionId • <b>Method:</b> @Model.PaymentMethod
                        </div>
                    }

                    <div class="d-grid gap-3">
                        <a asp-action="TrackOrder" asp-route-id="@Model.Id" class="btn btn-coffee btn-lg rounded-pill fw-bold py-3 shadow">
                            <i class="fas fa-map-marker-alt me-2"></i> Track Live Status
                        </a>
                        <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-dark btn-lg rounded-pill fw-bold py-3">
                            Order More Items
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Split Bill Modal -->
<div class="modal fade" id="splitBillModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-coffee">🍕 Split Your Bill</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p class="text-muted small mb-4">Select the items you want to pay for now. Other group members can pay for their items separately.</p>
                @foreach (var item in Model.OrderItems.Where(oi => !oi.IsPaid))
                {
                    <div class="d-flex align-items-center mb-3 p-3 border rounded-4">
                        <div class="form-check">
                            <input class="form-check-input split-item-checkbox" type="checkbox" value="@item.Id" data-price="@item.Subtotal" id="chk_@item.Id">
                        </div>
                        <label class="form-check-label flex-grow-1 ms-3 fw-bold" for="chk_@item.Id">
                            @item.ItemName <span class="text-muted small d-block">Qty: @item.Quantity • ৳@item.Subtotal</span>
                        </label>
                    </div>
                }
                <div class="bg-light p-3 rounded-4 d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Your Total</span>
                    <span class="fs-4 fw-bold text-coffee">৳<span id="splitDisplayTotal">0</span></span>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-coffee rounded-pill px-4" onclick="proceedToSplitPayment()">Pay Selected Items</button>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 25px !important; }
    .payment-method-card {
        display: block;
        padding: 20px;
        border: 2px solid #eee;
        border-radius: 20px;
        transition: all 0.3s;
        background: white;
    }
    .payment-method-card:hover { border-color: var(--coffee-color); transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .payment-method-card.bKash:hover { border-color: #e2136e; }
    .payment-method-card.Nagad:hover { border-color: #f6921e; }
    
    .celebration-background {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        opacity: 0.2;
    }
    .bg-success .celebration-background { background: linear-gradient(45deg, #2e7d32, #66bb6a); opacity: 0.9; }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.split-item-checkbox').change(function() {
                let total = 0;
                $('.split-item-checkbox:checked').each(function() {
                    total += parseFloat($(this).data('price'));
                });
                $('#splitDisplayTotal').text(total);
            });
        });

        function showSplitBillModal() {
            $('#splitBillModal').modal('show');
        }

        function proceedToSplitPayment() {
            const selectedIds = [];
            $('.split-item-checkbox:checked').each(function() {
                selectedIds.push($(this).val());
            });
            
            if (selectedIds.length === 0) {
                alert("Please select at least one item.");
                return;
            }
            
            const idsStr = selectedIds.join(',');
            // Default to bKash for split demo
            window.location.href = `/Payment/Gateway?orderId=@Model.Id&method=bKash&itemIds=${idsStr}`;
        }
    </script>
}
