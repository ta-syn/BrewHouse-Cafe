@model CafeManagement.Models.Order
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Order Confirmed";
}

<div class="container mt-5 py-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
                <div class="card-header bg-success text-white py-5 position-relative overflow-hidden">
                    <div class="celebration-background"></div>
                    <div class="position-relative z-1">
                        <div class="mb-4">
                            <i class="fas fa-check-circle fa-5x shadow-sm rounded-circle bg-white text-success"></i>
                        </div>
                        <h1 class="display-5 fw-bold mb-0">Order Confirmed!</h1>
                        <p class="opacity-75 mb-0">Your order is being prepared with care.</p>
                    </div>
                </div>
                
                <div class="card-body p-5">
                    <div class="mb-5">
                        <h4 class="text-coffee fw-bold mb-3">#@Model.Id</h4>
                        <p class="text-muted fs-5">Thank you for choosing us, <span class="text-dark fw-bold">@Model.CustomerName</span>! We've received your request and our chefs are already at work.</p>
                    </div>

                    <div class="row g-3 mb-5">
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="text-muted small text-uppercase letter-spacing-1 mb-1">Total Paid</div>
                                <div class="fs-4 fw-bold text-coffee">৳@Model.TotalAmount</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="text-muted small text-uppercase letter-spacing-1 mb-1">Order Type</div>
                                <div class="fs-4 fw-bold text-coffee">@(Model.TableId.HasValue ? "Dine-in" : "Take-away")</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-3">
                        <a asp-action="TrackOrder" asp-route-id="@Model.Id" class="btn btn-coffee btn-lg rounded-pill fw-bold py-3 shadow">
                            <i class="fas fa-map-marker-alt me-2"></i> Track Live Status
                        </a>
                        <a asp-controller="Home" asp-action="Menu" class="btn btn-outline-dark btn-lg rounded-pill fw-bold py-3">
                            Back to Menu
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 35px !important; }
    .celebration-background {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(45deg, #2e7d32, #66bb6a);
        opacity: 0.9;
    }
    .celebration-background::after {
        content: '';
        position: absolute;
        width: 200%; height: 200%;
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        animation: slide 20s linear infinite;
    }
    @@keyframes slide {
        from { transform: translate(0, 0); }
        to { transform: translate(-50%, -50%); }
    }
    .letter-spacing-1 { letter-spacing: 1px; }
</style>
