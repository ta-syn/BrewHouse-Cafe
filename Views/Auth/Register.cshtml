@model CafeManagement.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - CafeManagement</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root { --coffee-dark: #2C1810; --coffee-accent: #D4A574; --glass: rgba(255, 255, 255, 0.95); }
        body { font-family: 'Inter', sans-serif; background: #f8f9fa; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow-x: hidden; }
        .auth-container { width: 100%; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .auth-wrapper { width: 1000px; max-width: 100%; background: #fff; border-radius: 30px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15); min-height: 600px; }
        .side-panel { background: linear-gradient(rgba(44, 24, 16, 0.4), rgba(44, 24, 16, 0.6)), url('/images/auth/login_bg.png'); background-size: cover; background-position: center; padding: 60px; display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden; }
        .form-panel { padding: 60px; background: #fff; overflow-y: auto; max-height: 100%; }
        .display-font { font-family: 'Playfair Display', serif; }
        .btn-coffee { background: var(--coffee-dark); color: #fff; border-radius: 12px; padding: 12px; transition: all 0.3s; }
        .btn-coffee:hover { background: #3e2723; color: #fff; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .form-control { border-radius: 12px; padding: 12px 15px; border: 2px solid #f0f0f0; transition: all 0.3s; }
        .form-control:focus { border-color: var(--coffee-accent); box-shadow: none; }
        .input-group-text { border-radius: 12px; background: #f8f9fa; border: 2px solid #f0f0f0; }
        .letter-spacing-1 { letter-spacing: 1px; }

        @@media (max-width: 991px) {
            body { height: auto; overflow: auto; padding: 20px 0; }
            .auth-wrapper { border-radius: 20px; }
            .form-panel { padding: 40px 25px; }
            .side-panel { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-wrapper">
            <div class="row g-0 h-100">
                <div class="col-lg-6 d-none d-lg-flex side-panel text-white text-center">
                    <div class="position-relative z-1 w-100">
                        <div class="display-1 mb-4">✨</div>
                        <h1 class="display-font display-4 fw-bold mb-3">Join the Family</h1>
                        <p class="fs-5 opacity-75 mb-5">Create an account and start your journey with the most premium cafe experience.</p>
                        <div class="mt-5 pt-5">
                            <div class="d-flex justify-content-center gap-3">
                                <div class="p-3 bg-white bg-opacity-10 rounded-4">
                                    <h4 class="fw-bold mb-0">Fast</h4>
                                    <small class="opacity-75">Ordering</small>
                                </div>
                                <div class="p-3 bg-white bg-opacity-10 rounded-4">
                                    <h4 class="fw-bold mb-0">Live</h4>
                                    <small class="opacity-75">Tracking</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 form-panel">
                    <div class="mb-4 text-center text-lg-start">
                        <h2 class="fw-bold text-dark display-font h1 mb-2">Create Account</h2>
                        <p class="text-muted">Start your coffee journey today</p>
                    </div>

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 border-0 small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase letter-spacing-1 text-muted">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text border-end-0"><i class="fas fa-user opacity-50"></i></span>
                                <input asp-for="Name" class="form-control border-start-0" placeholder="e.g. John Doe" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase letter-spacing-1 text-muted">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text border-end-0"><i class="fas fa-envelope opacity-50"></i></span>
                                <input asp-for="Email" class="form-control border-start-0" placeholder="name@example.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase letter-spacing-1 text-muted">Password</label>
                            <div class="input-group">
                                <span class="input-group-text border-end-0"><i class="fas fa-lock opacity-50"></i></span>
                                <input asp-for="Password" type="password" id="reg-pass" class="form-control border-start-0 border-end-0" placeholder="••••••••" />
                                <span class="input-group-text border-start-0 bg-white" style="cursor: pointer;" onclick="togglePassword('reg-pass', this)">
                                    <i class="fas fa-eye opacity-50"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase letter-spacing-1 text-muted">Confirm Password</label>
                            <div class="input-group">
                                <span class="input-group-text border-end-0"><i class="fas fa-check-double opacity-50"></i></span>
                                <input asp-for="ConfirmPassword" type="password" id="reg-conf" class="form-control border-start-0 border-end-0" placeholder="••••••••" />
                                <span class="input-group-text border-start-0 bg-white" style="cursor: pointer;" onclick="togglePassword('reg-conf', this)">
                                    <i class="fas fa-eye opacity-50"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1"></span>
                        </div>

                        <button type="submit" class="btn btn-coffee w-100 fw-bold py-3 mt-2">
                            Create Account <i class="fas fa-user-plus ms-2"></i>
                        </button>

                        <div class="text-center mt-4">
                            <p class="text-muted small">Already have an account? 
                                <a asp-action="Login" class="text-dark fw-bold text-decoration-none border-bottom border-2 border-dark ms-1">Login here</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(inputId, iconEl) {
            const input = document.getElementById(inputId);
            const icon = iconEl.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>
