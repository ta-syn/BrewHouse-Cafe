@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Data Intelligence & AI Insights";
    var salesTrend = (List<object>)ViewBag.SalesTrend;
    var hourlyTraffic = (List<object>)ViewBag.HourlyTraffic;
    var categorySales = (List<object>)ViewBag.CategorySales;
    var aiInsights = (List<string>)ViewBag.AIInsights;
    var staffPerformance = (List<object>)ViewBag.StaffPerformance;
    var inventoryForecast = (List<object>)ViewBag.InventoryForecast;
    var financials = ViewBag.FinancialReport;
}

<div class="container-fluid">
    <!-- AI Intelligence Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 bg-dark text-white overflow-hidden position-relative">
                <div class="card-body p-4 position-relative z-1">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-primary bg-opacity-25 p-2 rounded-3 me-3">
                                    <i class="fas fa-brain fa-2x text-primary"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-0">AI Intelligence & Forecasting</h4>
                                    <p class="text-white-50 small mb-0">Live Business Analytics • Phase 4 Activated</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 text-md-end">
                            <div class="p-3 bg-white bg-opacity-10 rounded-4 d-inline-block text-start">
                                <div class="small text-white-50">Current Month Profit</div>
                                <div class="fs-4 fw-bold">৳@financials.profit.ToString("N0")</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="position-absolute top-0 end-0 p-3 opacity-25">
                    <i class="fas fa-chart-line fa-6x"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- 💡 AI Insights Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 border-start border-coffee border-5">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-coffee d-flex justify-content-between">
                        <span><i class="fas fa-bolt me-2 text-warning"></i> AI Smart Insights</span>
                        <span class="badge bg-success rounded-pill small" style="font-size: 0.7rem;">Live Analysis</span>
                    </h5>
                    <div class="row g-3">
                        @foreach (var insight in aiInsights)
                        {
                            <div class="col-md-4">
                                <div class="p-3 rounded-4 h-100 bg-light border shadow-sm transition-hover">
                                    <p class="mb-0 small fw-semibold text-dark">@insight</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- 📈 Sales Trend -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-coffee">Revenue & Orders Trend</h5>
                    <canvas id="salesChart" height="280"></canvas>
                </div>
            </div>
        </div>

        <!-- 📊 Staff Performance -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-coffee">Top Performer Staff</h5>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr class="small text-uppercase">
                                    <th>Staff</th>
                                    <th class="text-center">Orders</th>
                                    <th class="text-end">Avg. Speed</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic staff in staffPerformance)
                                {
                                    <tr>
                                        <td class="fw-bold small">@staff.staffName</td>
                                        <td class="text-center"><span class="badge bg-coffee rounded-pill">@staff.ordersCompleted</span></td>
                                        <td class="text-end text-success fw-bold small">@Math.Round(staff.avgMinutes, 1)m</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-4 p-3 bg-light rounded-4 small">
                        <i class="fas fa-info-circle me-1 text-primary"></i> Based on <b>Served</b> timestamp.
                    </div>
                </div>
            </div>
        </div>

        <!-- 📦 Inventory Forecast -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-coffee"><i class="fas fa-crystal-ball me-2"></i> Inventory Forecast (Next 7 Days)</h5>
                    <div class="list-group list-group-flush">
                        @foreach (dynamic item in inventoryForecast)
                        {
                            <div class="list-group-item border-0 px-0 py-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0 fw-bold">@item.itemName</h6>
                                    <small class="text-muted">Stock: @item.currentStock units</small>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-coffee">Need: @Math.Round(item.predictedNeed, 1)</div>
                                    <span class="badge @(item.status == "Critical" ? "bg-danger" : "bg-success") rounded-pill" style="font-size: 0.6rem;">@item.status</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 🕒 Hourly Traffic -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 text-coffee">Hourly Customer Density</h5>
                    <canvas id="trafficChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- 💰 Financial Overview -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-4">
                <div class="small text-white-50 text-uppercase">Monthly Revenue</div>
                <div class="display-6 fw-bold">৳@financials.revenue.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-danger text-white p-4">
                <div class="small text-white-50 text-uppercase">Estimated COGS</div>
                <div class="display-6 fw-bold">৳@financials.expenses.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-success text-white p-4">
                <div class="small text-white-50 text-uppercase">Net Profit</div>
                <div class="display-6 fw-bold">৳@financials.profit.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-info text-white p-4">
                <div class="small text-white-50 text-uppercase">Profit Margin</div>
                <div class="display-6 fw-bold">@Math.Round(financials.margin, 1)%</div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 20px !important; }
    .transition-hover:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; transition: all 0.3s; }
    .border-coffee { border-color: #2C1810 !important; }

    /* 📄 Professional PDF/Print Styles */
    @@media print {
        .admin-sidebar, .admin-header, .btn, .form-select, .badge.bg-success { display: none !important; }
        .main-content { padding: 0 !important; margin: 0 !important; width: 100% !important; }
        .card { border: 1px solid #eee !important; box-shadow: none !important; break-inside: avoid; }
        body { background: white !important; }
        .text-coffee { color: #000 !important; }
    }

</style>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const salesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesTrend));
        const trafficData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(hourlyTraffic));

        new Chart(document.getElementById('salesChart'), {
            type: 'line',
            data: {
                labels: salesData.map(d => d.date),
                datasets: [{
                    label: 'Revenue (৳)',
                    data: salesData.map(d => d.revenue),
                    borderColor: '#2C1810',
                    backgroundColor: 'rgba(44, 24, 16, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { responsive: true }
        });

        new Chart(document.getElementById('trafficChart'), {
            type: 'bar',
            data: {
                labels: trafficData.map(d => d.hour),
                datasets: [{
                    label: 'Density',
                    data: trafficData.map(d => d.count),
                    backgroundColor: '#f6921e',
                    borderRadius: 5
                }]
            }
        });
    </script>
}
