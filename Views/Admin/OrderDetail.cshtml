@using CafeManagement.Models.Enums
@model CafeManagement.Models.Order
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid">
    <div class="row g-4">
        <div class="col-lg-8">
            <!-- Order Items Card -->
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-receipt text-brown me-2"></i> Order Summary #@Model.Id</h5>
                    <button class="btn btn-sm btn-outline-dark rounded-pill" onclick="window.print()">
                        <i class="fas fa-print me-1"></i> Print Invoice
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 border-0">Item</th>
                                    <th class="text-center border-0">Price</th>
                                    <th class="text-center border-0">Qty</th>
                                    <th class="text-end pe-4 border-0">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td class="ps-4" data-label="Item">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 rounded-3 overflow-hidden bg-light shadow-sm d-none-mobile" style="width: 50px; height: 50px;">
                                                    @if (!string.IsNullOrEmpty(item.MenuItem?.ImageUrl))
                                                    {
                                                        <img src="@item.MenuItem.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@item.ItemName">
                                                    }
                                                    else
                                                    {
                                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted small">No Image</div>
                                                    }
                                                </div>
                                                <div class="fw-bold">@item.ItemName</div>
                                            </div>
                                        </td>
                                        <td class="text-center" data-label="Price">৳@item.UnitPrice</td>
                                        <td class="text-center" data-label="Qty">@item.Quantity</td>
                                        <td class="text-end pe-4 fw-bold" data-label="Subtotal">৳@item.Subtotal</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light-subtle">
                                <tr>
                                    <td colspan="3" class="text-end ps-4 py-3 fw-semibold">Subtotal:</td>
                                    <td class="text-end pe-4 py-3 fw-bold">৳@(Model.TotalAmount / (1 - Model.DiscountApplied/100))</td>
                                </tr>
                                @if(Model.DiscountApplied > 0)
                                {
                                    <tr class="text-success">
                                        <td colspan="3" class="text-end ps-4 py-1 fw-semibold">Discount (@Model.DiscountApplied%):</td>
                                        <td class="text-end pe-4 py-1 fw-bold">-৳@(Model.TotalAmount * (Model.DiscountApplied/100) / (1 - Model.DiscountApplied/100))</td>
                                    </tr>
                                }
                                <tr class="bg-brown text-white">
                                    <td colspan="3" class="text-end ps-4 py-3 fw-bold fs-5 rounded-start-bottom">Total Amount:</td>
                                    <td class="text-end pe-4 py-3 fw-bold fs-5 rounded-end-bottom">৳@Model.TotalAmount</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Order Info & Status Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Order Information</h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-md bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                            <i class="fas fa-user text-coffee fs-4"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Customer</div>
                            <div class="fw-bold fs-5">@(Model.IsWalkIn ? Model.CustomerName : Model.User?.Name)</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="text-muted small mb-1"><i class="far fa-calendar-alt me-1"></i> Order Date</div>
                        <div class="fw-semibold">@Model.CreatedAt.AddHours(6).ToString("MMMM dd, yyyy") at @Model.CreatedAt.AddHours(6).ToString("hh:mm tt")</div>
                    </div>

                    @if (Model.TableId.HasValue)
                    {
                        <div class="mb-4">
                            <div class="text-muted small mb-1"><i class="fas fa-chair me-1"></i> Assigned Table</div>
                            <span class="badge bg-coffee-light text-brown border-0 px-3 py-2 fs-6 rounded-pill">
                                Table @Model.Table?.TableNumber
                            </span>
                        </div>
                    }

                    <div class="mb-4 p-3 bg-light rounded-3">
                        <div class="text-muted small mb-1">Notes</div>
                        <p class="fst-italic mb-0 small">@(string.IsNullOrEmpty(Model.Notes) ? "No special instructions." : Model.Notes)</p>
                    </div>

                    <hr class="my-4">

                    @if (Model.Status == OrderStatus.Served || Model.Status == OrderStatus.Cancelled)
                    {
                        <div class="status-terminal p-4 rounded-4 text-center @(Model.Status == OrderStatus.Served ? "status-served" : "status-cancelled")">
                            <i class="fas @(Model.Status == OrderStatus.Served ? "fa-check-circle" : "fa-times-circle") fs-1 mb-3"></i>
                            <h5 class="fw-bold mb-1">Order @Model.Status</h5>
                            <p class="small mb-0 opacity-75">This order is finalized and cannot be modified.</p>
                        </div>
                    }
                    else
                    {
                        <form asp-action="UpdateOrderStatus" method="post" class="status-update-form">
                            <input type="hidden" name="orderId" value="@Model.Id" />
                            <label class="form-label fw-bold small text-uppercase letter-spacing-1 mb-3">Manage Status</label>
                            <div class="mb-3">
                                <select name="status" class="form-select border-2 rounded-pill py-2 px-4 fw-bold">
                                    @foreach (var status in Enum.GetValues<OrderStatus>())
                                    {
                                        <option value="@status" selected="@(Model.Status == status)">@status</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn btn-coffee w-100 rounded-pill fw-bold py-2 shadow-sm">
                                Update Status <i class="fas fa-sync-alt ms-2"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 25px !important; }
    .bg-coffee-light { background-color: #fdf5ef; }
    .text-coffee { color: #4e342e; }
    .btn-coffee { background: #4e342e; color: white; border: none; }
    .btn-coffee:hover { background: #3e2723; color: white; }
    .letter-spacing-1 { letter-spacing: 1px; }
    
    .status-terminal {
        transition: all 0.3s ease;
    }
    .status-served { background-color: #e8f5e9; color: #2e7d32; }
    .status-cancelled { background-color: #ffebee; color: #d32f2f; }
    
    @@media print {
        #sidebar, .navbar, .btn, form, hr, .status-update-form { display: none !important; }
        .container-fluid { padding: 0 !important; }
        .col-lg-8 { width: 100% !important; }
        .col-lg-4 { display: none !important; }
        .card { border: none !important; box-shadow: none !important; }
        .table-responsive { overflow: visible !important; }
    }
</style>
