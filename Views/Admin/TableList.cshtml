@using CafeManagement.Models.Enums
@model IEnumerable<CafeManagement.Models.CafeTable>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Table Management";
}

<div class="container-fluid">
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-chair text-brown me-2"></i> Table Layout & QR Ordering</h5>
            <div class="text-muted small">Generate encrypted QR codes for self-service ordering.</div>
        </div>
        <div class="card-body">
            <div class="row g-4">
                @foreach (var table in Model)
                {
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        @{
                            var statusColor = table.Status switch {
                                TableStatus.Available => "border-success bg-success-subtle",
                                TableStatus.Occupied => "border-danger bg-danger-subtle",
                                TableStatus.Reserved => "border-warning bg-warning-subtle",
                                _ => "border-secondary bg-light"
                            };
                            var iconColor = table.Status switch {
                                TableStatus.Available => "text-success",
                                TableStatus.Occupied => "text-danger",
                                TableStatus.Reserved => "text-warning",
                                _ => "text-secondary"
                            };
                        }
                        <div class="card @statusColor border-2 h-100 shadow-sm transition-hover">
                            <div class="card-body text-center">
                                <div class="mb-3 position-relative">
                                    <i class="fas fa-chair fa-3x @iconColor"></i>
                                    <span class="position-absolute top-0 start-50 translate-middle-x badge rounded-pill bg-dark" style="margin-top: -10px; font-size: 0.6rem;">T-@table.TableNumber</span>
                                </div>
                                <h4 class="fw-bold mb-1">Table @table.TableNumber</h4>
                                <p class="text-muted small mb-3">Capacity: @table.Capacity Persons</p>
                                
                                <div class="d-flex gap-2 mb-3">
                                    <form asp-action="UpdateTableStatus" method="post" class="flex-grow-1">
                                        <input type="hidden" name="id" value="@table.Id" />
                                        <select name="status" class="form-select form-select-sm border-0 shadow-none text-center fw-bold" onchange="this.form.submit()">
                                            @foreach (var status in Enum.GetValues<TableStatus>())
                                            {
                                                <option value="@status" selected="@(table.Status == status)">@status</option>
                                            }
                                        </select>
                                    </form>
                                    <button class="btn btn-sm btn-dark rounded-pill px-3" onclick="generateQR(@table.Id, @table.TableNumber)">
                                        <i class="fas fa-qrcode"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- QR Modal -->
<div class="modal fade" id="qrModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Table QR Code</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div id="qrCodeContainer" class="d-inline-block p-4 bg-white rounded-4 shadow-sm border mb-4"></div>
                <h4 class="fw-bold text-coffee" id="qrTableLabel">Table 0</h4>
                <p class="text-muted small px-4">Customers can scan this to order directly from this table without selecting it manually.</p>
                <div class="alert alert-info border-0 rounded-4 mx-3 small py-2">
                    <i class="fas fa-info-circle me-1"></i> This code is securely linked to Table <span id="qrTableNum"></span>.
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center pb-4">
                <button class="btn btn-coffee rounded-pill px-4" onclick="printQR()">
                    <i class="fas fa-print me-2"></i> Print QR Label
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .text-brown { color: #2C1810; }
    .bg-success-subtle { background-color: #f0fff4; }
    .bg-danger-subtle { background-color: #fff5f5; }
    .bg-warning-subtle { background-color: #fffaf0; }
    .transition-hover:hover { transform: translateY(-5px); transition: all 0.3s ease; }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        let qrGenerator = null;

        function generateQR(id, num) {
            $('#qrTableLabel').text('Table ' + num);
            $('#qrTableNum').text(num);
            $('#qrCodeContainer').empty();
            
            // Generate encrypted-like URL (Base64 for now, can be changed to Hash)
            const baseUrl = window.location.origin;
            const encodedId = btoa("table_" + id);
            const qrUrl = `${baseUrl}/Customer/Menu?tid=${encodedId}`;
            
            qrGenerator = new QRCode(document.getElementById("qrCodeContainer"), {
                text: qrUrl,
                width: 200,
                height: 200,
                colorDark : "#2C1810",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
            
            $('#qrModal').modal('show');
        }

        function printQR() {
            const content = document.getElementById('qrCodeContainer').innerHTML;
            const tableNum = $('#qrTableNum').text();
            const printWindow = window.open('', '_blank');
            printWindow.document.write(`
                <html>
                <head>
                    <title>Print QR - Table ${tableNum}</title>
                    <style>
                        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; padding: 50px; }
                        .card { border: 2px solid #2C1810; display: inline-block; padding: 30px; border-radius: 20px; }
                        h1 { color: #2C1810; margin-top: 20px; }
                        img { width: 250px; }
                    </style>
                </head>
                <body onload="window.print(); window.close();">
                    <div class="card">
                        <div>${content}</div>
                        <h1>BrewHouse Cafe</h1>
                        <h2>TABLE ${tableNum}</h2>
                        <p>Scan to Order & Pay</p>
                    </div>
                </body>
                </html>
            `);
            printWindow.document.close();
        }
    </script>
}
