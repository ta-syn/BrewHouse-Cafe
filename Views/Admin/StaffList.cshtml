@model IEnumerable<CafeManagement.Models.User>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Staff Management";
}

<div class="container-fluid">
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-dark"><i class="fas fa-users text-brown me-2"></i> Staff Members</h5>
            <a asp-action="AddStaff" class="btn btn-sm btn-dark rounded-pill px-3">
                <i class="fas fa-user-plus me-1"></i> Add New Staff
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0">Name</th>
                            <th class="border-0">Email</th>
                            <th class="border-0">Joined Date</th>
                            <th class="text-end pe-4 border-0">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@user.Name&background=random" class="rounded-circle me-3 shadow-sm border border-2 border-white" width="45">
                                        <div>
                                            <div class="fw-bold text-dark">@user.Name</div>
                                            <div class="text-muted small">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border rounded-pill px-3 py-2">
                                        <i class="far fa-calendar-alt me-1 text-brown"></i> @user.CreatedAt.ToString("MMM dd, yyyy")
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="confirmDeleteStaff(@user.Id, '@user.Name')">
                                        <i class="fas fa-user-minus me-1"></i> Remove
                                    </button>
                                </td>
                            </tr>
                        }
                        @if(!Model.Any()){
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="fas fa-users-slash fa-3x mb-3 d-block opacity-25"></i>
                                    No staff members found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDeleteStaff(id, name) {
            Swal.fire({
                title: 'Remove Staff Member?',
                text: `Are you sure you want to remove ${name} from the staff list?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, remove them!',
                cancelButtonText: 'Cancel',
                background: '#fff',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = `/Admin/DeleteStaff/${id}`;
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}
