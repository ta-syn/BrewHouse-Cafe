@model CafeManagement.Models.ViewModels.RegisterViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add New Staff";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">
                    <!-- Left Side: Illustration/Context -->
                    <div class="col-md-5 bg-dark text-white p-5 d-flex flex-column justify-content-center text-center">
                        <div class="mb-4">
                            <i class="fas fa-user-shield fa-5x text-coffee-light"></i>
                        </div>
                        <h3 class="fw-bold mb-3">Join the Team</h3>
                        <p class="opacity-75">Create a new administrative or staff account to manage the cafe operations efficiently.</p>
                        <div class="mt-4 pt-4 border-top border-secondary">
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="badge bg-coffee-light text-dark rounded-pill px-3 py-2">Security First</div>
                                <div class="badge bg-secondary rounded-pill px-3 py-2">Staff Only</div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Side: Form -->
                    <div class="col-md-7 bg-white p-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">Staff Credentials</h4>
                            <a asp-action="StaffList" class="btn btn-sm btn-light rounded-pill px-3">
                                <i class="fas fa-arrow-left me-1"></i> Back
                            </a>
                        </div>

                        <form asp-action="AddStaff" method="post" class="staff-form">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 mb-4"></div>

                            <div class="mb-4">
                                <label asp-for="Name" class="form-label small fw-bold text-uppercase letter-spacing-1">Full Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fas fa-user text-muted"></i></span>
                                    <input asp-for="Name" class="form-control border-2 border-start-0" placeholder="e.g. Nishan Ahmed" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Email" class="form-label small fw-bold text-uppercase letter-spacing-1">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-2 border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                                    <input asp-for="Email" class="form-control border-2 border-start-0" placeholder="staff@example.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label asp-for="Password" class="form-label small fw-bold text-uppercase letter-spacing-1">Password</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-2 border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                        <input asp-for="Password" type="password" id="staff-pass" class="form-control border-2 border-start-0 border-end-0" placeholder="••••••••" />
                                        <span class="input-group-text bg-white border-2 border-start-0" style="cursor: pointer;" onclick="togglePassword('staff-pass', this)">
                                            <i class="fas fa-eye text-muted opacity-50"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ConfirmPassword" class="form-label small fw-bold text-uppercase letter-spacing-1">Confirm</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-2 border-end-0"><i class="fas fa-check-double text-muted"></i></span>
                                        <input asp-for="ConfirmPassword" type="password" id="staff-conf" class="form-control border-2 border-start-0 border-end-0" placeholder="••••••••" />
                                        <span class="input-group-text bg-white border-2 border-start-0" style="cursor: pointer;" onclick="togglePassword('staff-conf', this)">
                                            <i class="fas fa-eye text-muted opacity-50"></i>
                                        </span>
                                    </div>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-coffee w-100 rounded-pill fw-bold py-3 mt-2 shadow-sm">
                                Register Staff Member <i class="fas fa-user-plus ms-2"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-4 { border-radius: 30px !important; }
    .text-coffee-light { color: #D4A574; }
    .bg-coffee-light { background-color: #fdf5ef; }
    .letter-spacing-1 { letter-spacing: 1px; }
    .staff-form .form-control:focus {
        border-color: #4e342e;
        box-shadow: none;
    }
    
    @@media (max-width: 767px) {
        .col-md-5.bg-dark { display: none !important; }
        .p-5 { padding: 1.5rem !important; }
        .rounded-4 { border-radius: 20px !important; }
    }
    
    .staff-form .input-group-text {
        border-color: #f0f0f0;
    }
    .btn-coffee { background: #4e342e; color: white; border: none; }
    .btn-coffee:hover { background: #3e2723; color: white; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
