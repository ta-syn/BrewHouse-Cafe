@model List<CafeManagement.Models.Session.CartItem>
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Your Shopping Cart";
}

<div class="container mt-5">
    <h2 class="display-5 fw-bold text-coffee mb-5"><i class="fas fa-shopping-cart me-3"></i> Your Cart</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="fas fa-cart-plus fa-5x text-muted mb-4 opacity-25"></i>
            <h3 class="fw-bold">Your cart is empty</h3>
            <p class="text-muted mb-4">Looks like you haven't added anything yet.</p>
            <a asp-controller="Home" asp-action="Menu" class="btn btn-coffee btn-lg px-5">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Product</th>
                                    <th class="text-center py-3 border-0">Price</th>
                                    <th class="text-center py-3 border-0">Quantity</th>
                                    <th class="text-end pe-4 py-3 border-0">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 rounded-3 overflow-hidden bg-light d-flex align-items-center justify-content-center" style="width: 54px; height: 54px;">
                                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                    {
                                                        <img src="@item.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@item.ItemName">
                                                    }
                                                    else
                                                    {
                                                        <span class="fs-2">@item.ImageEmoji</span>
                                                    }
                                                </div>
                                                <div>
                                                    <h6 class="fw-bold mb-0">@item.ItemName</h6>
                                                    <form asp-action="RemoveFromCart" method="post">
                                                        <input type="hidden" name="itemId" value="@item.MenuItemId" />
                                                        <button type="submit" class="btn btn-link btn-sm p-0 text-danger text-decoration-none">Remove</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-semibold text-muted">৳@item.UnitPrice</td>
                                        <td class="text-center">
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex justify-content-center">
                                                <input type="hidden" name="itemId" value="@item.MenuItemId" />
                                                <div class="input-group input-group-sm" style="width: 100px;">
                                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="btn btn-outline-secondary border-2">-</button>
                                                    <input type="text" class="form-control text-center border-2" value="@item.Quantity" readonly>
                                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="btn btn-outline-secondary border-2">+</button>
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end pe-4 fw-bold">৳@item.Subtotal</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 100px;">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    
                    <form asp-action="ApplyDiscount" method="post" class="mb-4">
                        <label class="form-label small text-muted">Discount Code</label>
                        <div class="input-group">
                            <input type="text" name="code" class="form-control border-2" placeholder="Enter code" value="@ViewBag.DiscountCode">
                            <button class="btn btn-outline-dark" type="submit">Apply</button>
                        </div>
                    </form>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold">৳@ViewBag.Subtotal</span>
                    </div>

                    @if (ViewBag.DiscountPercent > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Discount (@ViewBag.DiscountPercent%)</span>
                            <span>-৳@(ViewBag.Subtotal * ViewBag.DiscountPercent / 100)</span>
                        </div>
                    }

                    <hr class="my-3">

                    <div class="d-flex justify-content-between mb-4">
                        <span class="fs-5 fw-bold">Total</span>
                        <span class="fs-5 fw-bold text-coffee">৳@ViewBag.Total</span>
                    </div>

                    <a asp-action="Checkout" class="btn btn-coffee btn-lg w-100 rounded-pill fw-bold">Proceed to Checkout</a>
                    <a asp-controller="Home" asp-action="Menu" class="btn btn-link btn-sm w-100 text-muted mt-2 text-decoration-none"><i class="fas fa-arrow-left me-2"></i> Continue Shopping</a>
                </div>
            </div>
        </div>
    }
</div>
