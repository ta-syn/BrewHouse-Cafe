@model List<CafeManagement.Models.Session.CartItem>
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Checkout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="display-5 fw-bold text-coffee mb-4 text-center">Complete Your Order</h2>
            
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Order Review</h5>
                    @foreach(var item in Model)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center">
                                <div class="me-3 rounded-3 overflow-hidden bg-light shadow-sm d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background-color: #f8f9fa;">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@item.ItemName">
                                    }
                                    else
                                    {
                                        <span class="fs-4">@(item.ItemName.ToLower().Contains("coffee") ? "☕" : item.ItemName.ToLower().Contains("burger") ? "🍔" : item.ItemName.ToLower().Contains("pizza") ? "🍕" : "🍽️")</span>
                                    }
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@item.ItemName</h6>
                                    <small class="text-muted">@item.Quantity × ৳@item.UnitPrice</small>
                                </div>
                            </div>
                            <span class="fw-bold">৳@item.Subtotal</span>
                        </div>
                    }
                    
                    <hr class="my-4">
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span class="fw-semibold">৳@ViewBag.Subtotal</span>
                    </div>

                    @if (ViewBag.DiscountPercent > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success">
                            <span>Discount (@ViewBag.DiscountPercent%)</span>
                            <span>-৳@(ViewBag.Subtotal * ViewBag.DiscountPercent / 100)</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-3 mb-0">
                        <h4 class="fw-bold">Total Amount</h4>
                        <h4 class="fw-bold text-coffee">৳@ViewBag.Total</h4>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 p-4">
                <form asp-action="Checkout" method="post">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Select Table Number</label>
                        <select name="tableId" class="form-select border-2 rounded-pill">
                            <option value="">Select Table (Optional)</option>
                            @if (ViewBag.Tables != null)
                            {
                                foreach (var table in (List<CafeManagement.Models.CafeTable>)ViewBag.Tables)
                                {
                                    <option value="@table.Id">Table @table.TableNumber (@table.Status)</option>
                                }
                            }
                        </select>
                        <small class="text-muted ms-2">Select your table if you are dining in.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Special Notes (Optional)</label>
                        <textarea name="notes" class="form-control border-2" rows="3" placeholder="e.g. Extra hot, no sugar, etc."></textarea>
                    </div>
                    
                    <div class="bg-light p-3 rounded-3 mb-4 text-center">
                        <p class="mb-0 small text-muted"><i class="fas fa-info-circle me-2"></i> Payment will be collected at the cafe (Cash/Card).</p>
                    </div>

                    <button type="submit" class="btn btn-coffee btn-lg w-100 rounded-pill fw-bold py-3 shadow">
                        Place Order ৳@ViewBag.Total
                    </button>
                    <a asp-action="ViewCart" class="btn btn-link btn-sm w-100 text-muted mt-2 text-decoration-none">Return to Cart</a>
                </form>
            </div>
        </div>
    </div>
</div>
